# Dataset and output roots.
# Each dataset must live at: $MEMCF_DATA_ROOT/<dataset>/items.json, user_sequences_10.json, user_negatives_10.json
export MEMCF_DATA_ROOT=/home/ubuntu/24nam.nh/video_games_data/runtime_data
export MEMCF_EVAL_ROOT=/home/ubuntu/24nam.nh/video_games_data/evaluation_results_memcf
export MEMCF_MEMORY_ROOT=/home/ubuntu/24nam.nh/video_games_data/agent_memory_memcf

# OpenAI-compatible local chat endpoint.
export chat_api_base=http://127.0.0.1:8000/v1
export api_base=http://127.0.0.1:8000/v1
export chat_model_name=gpt-3.5-turbo-16k-0613

# Local embedding model used for memory embedding when available.
export embedding_model_name=/home/ubuntu/qwen_embed

# Optional generation controls. Support depends on your local API server.
export MEMCF_TEMPERATURE=0.0
export MEMCF_RANK_MAX_TOKENS=1200
export MEMCF_MEMORY_MAX_TOKENS=700
export MEMCF_RANK_RETRIES=3
